rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── Helpers that safely read the caller's own user doc ─────────────
    // We use exists() before get() and .get('role', '') with a default so
    // newly-signed-up users (whose doc may not have a role yet) never
    // throw during rule evaluation.
    function callerUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function callerHasUserDoc() {
      return isSignedIn() && exists(callerUserPath());
    }
    function callerRole() {
      return callerHasUserDoc() ? get(callerUserPath()).data.get('role', '') : '';
    }
    function isAdmin() {
      return callerRole() == 'admin' || callerRole() == 'ecosystem-owner';
    }

    // ─── users ─────────────────────────────────────────────────────────
    // Owners always have full access to their own doc. Admin access to
    // other users' profiles is intentionally NOT enforced here, because
    // that would require a recursive get() that can fail during the
    // initial sign-up handshake. Admin features that need to read other
    // users go through server-side routes (Admin SDK bypasses rules).
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ─── startups / mentors ────────────────────────────────────────────
    match /startups/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
      allow delete: if isAdmin();
    }
    match /mentors/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── documents (evidence metadata) ─────────────────────────────────
    match /documents/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
    }

    // ─── AI agent runs / verification results ──────────────────────────
    match /autofill_profiles/{id} {
      allow read, write: if isSignedIn() && (isOwner(resource.data.ownerUid) || isAdmin());
    }
    match /verification_results/{id} {
      // Holder writes their own run (orchestrator persists from the client);
      // admins can read any run. For tight prod rules, route writes through
      // the server and lock client writes off entirely.
      allow read: if isSignedIn() && (isOwner(id) || isAdmin());
      allow create, update: if isSignedIn() && (isOwner(id) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── passports ─────────────────────────────────────────────────────
    match /passports/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /stamps/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /badges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /linkages/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /admin_reviews/{id} {
      allow read, write: if isAdmin();
    }
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
