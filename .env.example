# ─────────────────────────────────────────────────────────────────────────────
# TrustPass AI — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Firebase (client SDK — safe to expose) ────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server-only — keep secret) ────────────────────────────
# For server-side Firestore writes and ID token verification on Cloud Run.
# Get from: GCP Console → IAM & Admin → Service Accounts → create key (JSON)
# Either inline the whole JSON in one line, OR set FIREBASE_SERVICE_ACCOUNT_PATH.
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# ─── AI providers (server-only) — fallback chain in this order ─────────────
# Set whichever you have. The client tries them top-down on each call and
# falls forward to the next on retryable errors (429, network).
#
# 1. Ollama Cloud  https://ollama.com (get a cloud key, models like
#                  "gemini-3-flash-preview:cloud")
OLLAMA_API_KEY=
OLLAMA_MODEL=gemini-3-flash-preview:cloud
# OLLAMA_BASE_URL=https://ollama.com/v1

# 2. NVIDIA NIM    https://build.nvidia.com — bearer key starts with nvapi-
NVIDIA_API_KEY=
NVIDIA_MODEL=google/gemma-3n-e4b-it

# 3. Gemini direct https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── App config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TrustPass AI
